{
  "name": "bhw-pas",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:docker": "docker compose -f docker-compose.dev.yml up -d",
    "build": "next build",
    "start": "next start",
    "start:prod": "NODE_ENV=production next start",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "format:check": "biome format",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "db:drop": "drizzle-kit drop",
    "db:check": "drizzle-kit check",
    "ci": "pnpm lint && pnpm typecheck && pnpm build",
    "clean": "rm -rf .next node_modules",
    "analyze": "ANALYZE=true pnpm build",
    "backup:db": "bash scripts/backup-db.sh",
    "backup:redis": "bash scripts/backup-redis.sh",
    "backup:all": "bash scripts/backup-all.sh",
    "restore:db": "bash scripts/restore-db.sh",
    "health": "curl -s http://localhost:3000/api/health | jq",
    "docker:build": "docker build -t bhw-pas:latest .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:clean": "docker compose down -v",
    "migration:create": "drizzle-kit generate",
    "migration:run": "drizzle-kit migrate",
    "migration:revert": "drizzle-kit drop",
    "preview": "NODE_ENV=production next start -p 3000",
    "postinstall": "node scripts/validate-env.js"
  },
  "dependencies": {
